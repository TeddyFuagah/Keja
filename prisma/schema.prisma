// Simplified schema for SQLite development
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User model
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  firstName     String
  lastName      String
  phone         String?
  profileImage  String?
  role          String   @default("buyer") // buyer, agent, agency, host, admin
  savedProperties String @default("[]") // JSON string
  searchHistory String  @default("[]") // JSON string
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  propertiesAsAgent    Property[] @relation("PropertyAgent")
  propertiesAsAgency   Property[] @relation("PropertyAgency")
  propertiesAsHost     Property[] @relation("PropertyHost")
  reviews              Review[]
  bookingsAsGuest      Booking[]  @relation("BookingGuest")
  bookingsAsHost       Booking[]  @relation("BookingHost")
  collections          Collection[]
  inquiries            PropertyInquiry[]
  priceAlerts          PriceAlert[]
  accounts             Account[]
  sessions             Session[]
}

// Property model
model Property {
  id                String   @id @default(cuid())
  title             String
  description       String
  type              String   // residential, commercial, land, industrial
  category          String   // buy, rent, short-stay, land, commercial
  status            String   @default("available")
  price             Float
  monthlyRent       Float?
  depositAmount     Float?
  location          String   // JSON string for location data
  images            String   @default("[]") // JSON string
  videos            String   @default("[]") // JSON string
  amenities         String   @default("[]") // JSON string
  bedrooms          Int      @default(0)
  bathrooms         Float    @default(0)
  sizeSqft          Int      @default(0)
  agentId           String?
  agencyId          String?
  hostId            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  views             Int      @default(0)
  featured          Boolean  @default(false)
  promoted          Boolean  @default(false)

  // Relations
  agent             User?    @relation("PropertyAgent", fields: [agentId], references: [id])
  agency            User?    @relation("PropertyAgency", fields: [agencyId], references: [id])
  host              User?    @relation("PropertyHost", fields: [hostId], references: [id])
  inquiries         PropertyInquiry[]
  bookings          Booking[]
  priceAlerts       PriceAlert[]
}

// Review model
model Review {
  id         String   @id @default(cuid())
  targetId   String   // Property, Agent, Agency, or Host ID
  targetType String   // property, agent, agency, host
  userId     String
  rating     Int      // 1-5
  comment    String
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Property Inquiry model
model PropertyInquiry {
  id             String   @id @default(cuid())
  propertyId     String
  userId         String
  inquiryType    String   // viewing, information, offer
  message        String?
  contactMethod  String   @default("whatsapp") // whatsapp, call, email
  status         String   @default("new") // new, contacted, scheduled, completed, closed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Booking model
model Booking {
  id             String   @id @default(cuid())
  propertyId     String
  guestId        String
  hostId         String
  checkInDate    DateTime
  checkOutDate   DateTime
  guests         Int
  totalNights    Int
  nightlyRate    Float
  cleaningFee    Float   @default(0)
  serviceFee     Float   @default(0)
  totalAmount    Float
  status         String   @default("pending") // pending, confirmed, cancelled, completed
  paymentStatus  String   @default("pending") // pending, paid, refunded
  specialRequests String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guest    User     @relation("BookingGuest", fields: [guestId], references: [id], onDelete: Cascade)
  host     User     @relation("BookingHost", fields: [hostId], references: [id], onDelete: Cascade)
}

// Collection model
model Collection {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  properties  String   @default("[]") // JSON string of property IDs
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Price Alert model
model PriceAlert {
  id         String    @id @default(cuid())
  userId     String
  propertyId String?
  minPrice   Float?
  maxPrice   Float?
  location   String?
  propertyType String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id])
}

// NextAuth Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth Verification Token model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}